# File: .dockerignore
# Category: Config
# Description: Specifies patterns of files and directories to ignore when building Docker images.
# Maintainer: ryumada

.git
.github
.gitignore
.next
.env
.DS_Store
npm-debug.log
yarn-debug.log
yarn-error.log

# Ignore local node_modules to prevent sending gigabytes of context to the Docker daemon
app/*/node_modules

# Ignore other local development artifacts
app/*/.next
app/*/.turbo
app/*/out
app/*/build

# Ignore REPO_MAPs generated by the utility scripts
REPO_MAP*.md
app/*/REPO_MAP*.md
