{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Next.js: debug server-side (Worker/9230)",
            "type": "node",
            "request": "attach",
            "address": "localhost",
            "port": 9230,
            "autoAttachChildProcesses": true,
            "localRoot": "${workspaceFolder}/app/essentia",
            "remoteRoot": "/usr/src/app",
            "skipFiles": [
                "**/node_modules/**",
                "<node_internals>/**"
            ],
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "[project]/*": "${workspaceFolder}/app/essentia/*",
                "[project]/src/*": "${workspaceFolder}/app/essentia/src/*",
                "turbopack:///[project]/*": "${workspaceFolder}/app/essentia/*",
                "webpack://temp/./*": "${workspaceFolder}/app/essentia/*",
                "webpack:///src/*": "${workspaceFolder}/app/essentia/src/*"
            }
        },
        {
            "name": "Next.js: debug server-side (CLI/9229)",
            "type": "node",
            "request": "attach",
            "address": "localhost",
            "port": 9229,
            "autoAttachChildProcesses": true,
            "localRoot": "${workspaceFolder}/app/essentia",
            "remoteRoot": "/usr/src/app",
            "skipFiles": [
                "**/node_modules/**",
                "<node_internals>/**"
            ],
            "sourceMaps": true
        },
        {
            "name": "Next.js: debug client-side (Chrome)",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:20001",
            "webRoot": "${workspaceFolder}/app/essentia"
        },
        {
            "name": "Next.js: debug client-side (Firefox)",
            "type": "firefox",
            "request": "launch",
            "url": "http://localhost:20001",
            "reAttach": true,
            "pathMappings": [
                {
                    "url": "webpack://_N_E",
                    "path": "${workspaceFolder}/app/essentia"
                }
            ]
        }
    ],
    "compounds": [
        {
            "name": "Next.js: debug full stack (Chrome)",
            "configurations": [
                "Next.js: debug server-side (Worker/9230)",
                "Next.js: debug server-side (CLI/9229)",
                "Next.js: debug client-side (Chrome)"
            ]
        },
        {
            "name": "Next.js: debug full stack (Firefox)",
            "configurations": [
                "Next.js: debug server-side (Worker/9230)",
                "Next.js: debug server-side (CLI/9229)",
                "Next.js: debug client-side (Firefox)"
            ]
        }
    ]
}
